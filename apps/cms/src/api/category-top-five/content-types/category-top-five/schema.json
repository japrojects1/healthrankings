{
  "kind": "collectionType",
  "collectionName": "category_top_fives",
  "info": {
    "singularName": "category-top-five",
    "pluralName": "category-top-fives",
    "displayName": "Category Top 5",
    "description": "Ordered top 5 device reviews per category (e.g. BP monitors, smart scales)."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "required": true,
      "unique": true
    },
    "category": {
      "type": "string",
      "required": true,
      "maxLength": 96
    },
    "title": {
      "type": "string",
      "required": true
    },
    "subtitle": {
      "type": "text"
    },
    "entries": {
      "type": "component",
      "repeatable": true,
      "component": "review.top5-entry",
      "required": true,
      "min": 1,
      "max": 5
    }
  }
}
