{
  "kind": "collectionType",
  "collectionName": "category_top_fives",
  "info": {
    "singularName": "category-top-five",
    "pluralName": "category-top-fives",
    "displayName": "Category Top 5",
    "description": "Ordered top 5 device reviews per category (e.g. BP monitors, smart scales)."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "required": true,
      "unique": true
    },
    "category": {
      "type": "string",
      "required": true,
      "maxLength": 96
    },
    "productType": {
      "type": "enumeration",
      "enum": ["device", "supplement"],
      "default": "device",
      "required": false
    },
    "title": {
      "type": "string",
      "required": true
    },
    "subtitle": {
      "type": "text"
    },
    "intro": {
      "type": "text",
      "description": "Brief educational intro paragraph displayed under the H1."
    },
    "categoryLabel": {
      "type": "string",
      "maxLength": 96,
      "description": "Optional human-readable label (e.g. 'Blood Pressure Monitors for AFib'). Defaults to category."
    },
    "metaTitle": {
      "type": "string",
      "maxLength": 200
    },
    "metaDescription": {
      "type": "text"
    },
    "entries": {
      "type": "component",
      "repeatable": true,
      "component": "review.top5-entry",
      "required": true,
      "min": 1,
      "max": 5
    },
    "faqs": {
      "type": "component",
      "repeatable": true,
      "component": "review.faq-item"
    },
    "relatedConditions": {
      "type": "component",
      "repeatable": true,
      "component": "review.related-condition"
    }
  }
}
