{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article",
    "description": "Editorial health guides (formerly healthrankings-article-*.html)."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "unique": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "tag": {
      "type": "string"
    },
    "topic": {
      "type": "string"
    },
    "subtitle": {
      "type": "text"
    },
    "metaDescription": {
      "type": "text"
    },
    "readTime": {
      "type": "string"
    },
    "publishedDate": {
      "type": "date"
    },
    "authorLine": {
      "type": "string"
    },
    "body": {
      "type": "text",
      "required": true
    },
    "heroImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "sourceHtmlPath": {
      "type": "string",
      "private": true
    }
  }
}
